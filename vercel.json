{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "crons": [
    { "path": "/api/meta-capi", "schedule": "0 * * * *" },
    { "path": "/api/prune", "schedule": "30 20 * * *" }
  ],
  "headers": [
    {
      "source": "/device-prices.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
